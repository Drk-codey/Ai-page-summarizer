GROQ_API_KEY=your_groq_api_key_here

# OPTIONAL: Override the AI model.
# Free Groq models:
#   llama-3.1-8b-instant   (default — fastest)
#   llama3-70b-8192        (smarter, slightly slower)
#   mixtral-8x7b-32768     (large context, good for long articles)
AI_MODEL=llama-3.1-8b-instant

# OPTIONAL: Max tokens in AI response (default: 1024)
MAX_TOKENS=1024

# OPTIONAL: Rate limit — max requests per IP per minute (default: 15)
RATE_LIMIT_MAX=15

# OPTIONAL
# PORT=3000
